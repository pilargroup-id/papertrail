<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pilih Divisi - FRP System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <style>
        :root { --primary: #4f46e5; --secondary: #0ea5e9; --bg: #f8fafc; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: white; padding: 3rem; border-radius: 2rem; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1); width: 100%; max-width: 500px; text-align: center; border: 1px solid #e2e8f0; }
        .icon-box { width: 64px; height: 64px; background: #f0fdf4; border-radius: 1rem; display: flex; align-items: center; justify-content: center; color: #16a34a; margin: 0 auto 2rem; }
        h1 { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: 2rem; }
        .division-grid { display: flex; flex-direction: column; gap: 1rem; }
        .division-btn {
            display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; border: 1.5px solid #e2e8f0; border-radius: 1.25rem;
            background: white; cursor: pointer; transition: all 0.2s; text-align: left; width: 100%; font-size: 1rem; font-weight: 600; color: #334155;
        }
        .division-btn:hover { border-color: #16a34a; background: #f0fdf4; color: #16a34a; transform: translateX(5px); }
        .division-btn .subtitle { display: block; font-size: 0.75rem; color: #94a3b8; font-weight: 400; margin-top: 2px; }
        .division-btn:hover .subtitle { color: #16a34a; opacity: 0.8; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-box"><span class="material-icons-round">account_tree</span></div>
        <h1>Pilih Divisi</h1>
        <p style="color:#64748b; margin-bottom:1.5rem; font-size:0.875rem;">Pilih divisi Anda di perusahaan ini</p>
        <form action="/select-division" method="POST" class="division-grid">
            <% divisions.forEach(div => { %>
                <button type="submit" name="division" value="<%= div.class %>" class="division-btn">
                    <div>
                        <span><%= div.class %></span>
                        <span class="subtitle"><%= div.jobLevel %></span>
                    </div>
                    <span class="material-icons-round">chevron_right</span>
                </button>
            <% }); %>
        </form>
        <a href="/select-company" style="display:inline-flex;align-items:center;gap:6px;margin-top:1.5rem;color:#94a3b8;font-size:0.875rem;text-decoration:none;font-weight:500;">
            <span class="material-icons-round" style="font-size:16px;">arrow_back</span> Kembali ke Pilih Perusahaan
        </a>
        <br>
        <a href="/logout" style="display:inline-flex;align-items:center;gap:6px;margin-top:0.75rem;color:#94a3b8;font-size:0.875rem;text-decoration:none;font-weight:500;">
            <span class="material-icons-round" style="font-size:16px;">logout</span> Logout
        </a>
    </div>
</body>
</html>
