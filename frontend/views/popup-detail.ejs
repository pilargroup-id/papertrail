<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Detail FRP</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: transparent; padding: 0; min-height: auto; }
    .main-content { padding: 1rem; min-height: auto; padding-bottom: 120px; }
    .form-container { box-shadow: none; border: none; padding: 1rem; margin: 0; max-width: 100%; background: transparent; }
    .form-container::before { display: none; }
    .floating-actions {
      position: fixed;
      bottom: 0; left: 0; width: 100%;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(8px);
      padding: 1rem 2rem;
      border-top: 1px solid #e2e8f0;
      display: flex; justify-content: flex-end; gap: 1rem;
      box-shadow: 0 -4px 15px rgba(0,0,0,0.05);
      z-index: 1000;
    }
    input[readonly], select[disabled], textarea[readonly] {
        background-color: #f8fafc;
        cursor: not-allowed;
        color: #475569;
        opacity: 1;
    }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    
    /* Small Button Styles */
    .btn-sm {
        padding: 6px 12px !important;
        font-size: 13px !important;
        gap: 4px !important;
    }
    .btn-sm .material-icons-round {
        font-size: 18px !important;
    }
    .floating-actions {
        padding: 0.75rem 1.5rem !important;
        gap: 0.5rem !important;
    }
  </style>
</head>
<body>
  <% const isIT = (user.class === 'IT'); %>
  <div class="main-content">
    <div class="form-container">
      
      <div class="header-card" style="margin-bottom: 1.5rem; padding-bottom: 1rem;">
        <div class="header-icon-wrap" style="width: 48px; height: 48px;">
          <span class="material-icons-round" style="font-size: 1.5rem;">description</span>
        </div>
        <div>
          <h2 style="font-size: 1.5rem;">Form Request Payment (<%= data.frpNo %>)</h2>
          <p style="font-size: 0.875rem;">Status: 
            <strong style="color: <%= data.status === 'APPROVED' ? '#10b981' : (data.status === 'REJECTED' ? '#ef4444' : '#f59e0b') %>">
                <%= data.status %>
            </strong>
          </p>
        </div>
      </div>

      <form id="detailForm">
        <!-- Section 1: FRP Info -->
        <div class="form-section">
          <div class="section-header">
            <span class="material-icons-round section-icon">info</span>
            <h3>Informasi FRP</h3>
          </div>
          <div class="form-grid cols-2">
            <div class="form-group">
              <label>Company Name</label>
              <select name="companyName" <%= isIT ? '' : 'disabled' %>>
                <% companies.forEach(c => { %>
                  <option value="<%= c.name %>" <%= data.companyName===c.name?'selected':'' %>><%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>Tanggal FRP</label>
              <input type="date" name="tanggalFrp" value="<%= data.tanggalFrp %>" <%= isIT ? '' : 'readonly' %>>
            </div>
          </div>
          <div class="form-grid cols-2">
            <% if (data.companyName === 'PT PILAR NIAGA MAKMUR') { %>
              <div class="form-group">
                <label>Divisi</label>
                <input type="text" name="divisi" value="<%= data.divisi %>" <%= isIT ? '' : 'readonly' %>>
              </div>
            <% } %>
            <div class="form-group">
              <label>Diminta Oleh</label>
              <input type="text" name="dimintaOleh" value="<%= data.dimintaOleh %>" <%= isIT ? '' : 'readonly' %>>
            </div>
          </div>
          <div class="form-group full-width" style="margin-top: 15px;">
            <label>Keterangan FRP</label>
            <textarea name="keteranganFrp" rows="2" <%= isIT ? '' : 'readonly' %>><%= data.keteranganFrp || '' %></textarea>
          </div>
        </div>

        <!-- Section 2: Vendor & Payment -->
        <div class="form-section">
          <div class="section-header">
            <span class="material-icons-round section-icon">store</span>
            <h3>Vendor & Pembayaran</h3>
          </div>
          <div class="form-grid cols-2">
            <div class="form-group">
              <label>Vendor</label>
              <input type="text" name="vendor" value="<%= data.vendor %>" <%= isIT ? '' : 'readonly' %>>
            </div>
            <div class="form-group">
              <label>Internal PO Number</label>
              <input type="text" name="internalPoNumber" value="<%= data.internalPoNumber || '' %>" <%= isIT ? '' : 'readonly' %>>
            </div>
          </div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label>Ext Doc Type</label>
              <select name="extDocType" <%= isIT ? '' : 'disabled' %>>
                <option value="invoice" <%= data.extDocType==='invoice'?'selected':'' %>>Invoice</option>
                <option value="kontrak" <%= data.extDocType==='kontrak'?'selected':'' %>>Kontrak</option>
                <option value="kwitansi" <%= data.extDocType==='kwitansi'?'selected':'' %>>Kwitansi</option>
                <option value="nota" <%= data.extDocType==='nota'?'selected':'' %>>Nota</option>
                <option value="other" <%= data.extDocType==='other'?'selected':'' %>>Lainnya</option>
                <option value="" <%= !data.extDocType?'selected':'' %>>-</option>
              </select>
            </div>
            <div class="form-group">
              <label>Ext Doc Number</label>
              <input type="text" name="extDocNumber" value="<%= data.extDocNumber || '' %>" <%= isIT ? '' : 'readonly' %>>
            </div>
            <div class="form-group">
              <label>Payment Method</label>
              <select name="paymentMethod" <%= isIT ? '' : 'disabled' %>>
                <option value="Transfer" <%= data.paymentMethod==='Transfer'?'selected':'' %>>Transfer</option>
                <option value="Cash" <%= data.paymentMethod==='Cash'?'selected':'' %>>Cash</option>
                <option value="Giro" <%= data.paymentMethod==='Giro'?'selected':'' %>>Giro</option>
              </select>
            </div>
          </div>
          <div class="form-grid cols-3">
            <div class="form-group">
              <label>Payment Date</label>
              <input type="date" name="paymentDate" value="<%= data.paymentDate %>" <%= isIT ? '' : 'readonly' %>>
            </div>
            <div class="form-group">
              <label>Bank Tujuan</label>
              <input type="text" name="bankTujuan" value="<%= data.bankTujuan || '' %>" <%= isIT ? '' : 'readonly' %>>
            </div>
            <div class="form-group full-width">
              <label>Rekening Bank Tujuan</label>
              <input type="text" name="rekBankTujuan" value="<%= data.rekBankTujuan || '' %>" <%= isIT ? '' : 'readonly' %>>
            </div>
          </div>
        </div>

        <!-- Section 3: Checklist Documents -->
        <div class="form-section">
          <div class="section-header">
            <span class="material-icons-round section-icon">checklist</span>
            <h3>Checklist Documents</h3>
          </div>
          <div class="checklist-grid">
            <% 
            const allDocs = ["Form Request Payment", "Tanda Terima Asli", "Invoice / Kontrak", "Surat Jalan Asli / Berita Acara", "Faktur Pajak", "Purchase Order"];
            const checkedDocs = data.checkDocs || [];
            allDocs.forEach(doc => { 
                const isChecked = checkedDocs.includes(doc);
            %>
            <label class="checklist-item" style="<%= isChecked ? 'border-color: var(--primary); background: var(--primary-light);' : (isIT ? '' : 'opacity:0.6;') %>">
              <input type="checkbox" name="checkDocs[]" value="<%= doc %>" <%= isChecked ? 'checked' : '' %> <%= isIT ? '' : 'disabled' %>>
              <span class="checkmark"></span>
              <span><%= doc %></span>
            </label>
            <% }); %>
          </div>
        </div>

        <!-- Section 4: Line Items -->
        <div class="form-section">
          <div class="section-header">
            <span class="material-icons-round section-icon">receipt_long</span>
            <h3>Detail Pembayaran</h3>
          </div>
          <div class="line-items-table">
            <table id="lineItemsTable">
              <thead>
                <tr>
                  <th class="th-no">No</th>
                  <th class="th-memo">Memo / Keterangan</th>
                  <th class="th-budget">Budget ID</th>
                  <th class="th-amount">Amount (IDR)</th>
                </tr>
              </thead>
              <tbody id="lineItemsBody">
                <% 
                  let total = 0;
                  if(data.items && data.items.length) {
                    data.items.forEach((i, idx) => { 
                      const raw = String(i.amount || '0').replace(/\./g, '').replace(/[^0-9]/g, '');
                      const num = parseInt(raw, 10) || 0;
                      total += num;
                %>
                  <tr class="line-item-row">
                    <td class="td-no"><%= idx + 1 %></td>
                    <td><input type="text" class="item-memo" name="items[<%= idx %>][memo]" value="<%= i.memo %>" <%= isIT ? '' : 'readonly' %>></td>
                    <td><input type="text" class="item-budget" name="items[<%= idx %>][budgetId]" value="<%= i.budgetId %>" <%= isIT ? '' : 'readonly' %>></td>
                    <td><input type="text" class="item-amount" name="items[<%= idx %>][amount]" value="<%= i.amount %>" style="text-align: right; font-family: monospace;" <%= isIT ? '' : 'readonly' %>></td>
                  </tr>
                <% 
                    }); 
                  }
                %>
              </tbody>
              <tfoot>
                <tr class="total-row">
                  <td colspan="3" class="total-label">Total</td>
                  <td class="total-amount" id="totalAmount">IDR <%= total.toLocaleString('id-ID') %></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>



        <!-- Section 6: Approval -->
        <div class="form-section" style="margin-bottom: 0;">
          <div class="section-header">
            <span class="material-icons-round section-icon">approval</span>
            <h3>Approval</h3>
          </div>
          <div class="form-grid cols-2">
            <div class="form-group">
              <label>Request By</label>
              <select name="requestBy" <%= isIT ? '' : 'disabled' %>>
                <% employees.forEach(e => { %>
                  <option value="<%= e.fullName %>" <%= data.requestBy===e.fullName?'selected':'' %>><%= e.fullName %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>Approved By (Head/Manager)</label>
              <select name="approvedBy" <%= isIT ? '' : 'disabled' %>>
                <% employees.filter(e => e.jobLevel === 'Manager' || e.jobLevel === 'Direktur' || e.jobLevel === 'Komisaris').forEach(e => { %>
                  <option value="<%= e.fullName %>" <%= data.approvedBy===e.fullName?'selected':'' %>><%= e.fullName %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>

      </form>
    </div>
  </div>

  <div class="floating-actions">
    <% if(data.status === 'APPROVED') { %>
        <!-- Form Cetak PDF -->
        <form id="pdfForm" method="POST" style="margin:0; display: flex; gap: 0.5rem;" target="_blank">
            <input type="hidden" name="frpNo" value="<%= data.frpNo %>">
            <input type="hidden" name="companyName" value="<%= data.companyName %>">
            <input type="hidden" name="divisi" value="<%= data.divisi %>">
            <input type="hidden" name="dimintaOleh" value="<%= data.dimintaOleh %>">
            <input type="hidden" name="vendor" value="<%= data.vendor %>">
            <input type="hidden" name="tanggalFrp" value="<%= data.tanggalFrp %>">
            <input type="hidden" name="requestBy" value="<%= data.requestBy || data.dimintaOleh || data.createdBy || '' %>">
            <input type="hidden" name="approvedBy" value="<%= data.approvedBy || data.approvedByActual || '' %>">
            <input type="hidden" name="bankTujuan" value="<%= data.bankTujuan %>">
            <input type="hidden" name="rekBankTujuan" value="<%= data.rekBankTujuan %>">
            <input type="hidden" name="internalPoNumber" value="<%= data.internalPoNumber %>">
            <input type="hidden" name="extDocType" value="<%= data.extDocType %>">
            <input type="hidden" name="extDocNumber" value="<%= data.extDocNumber %>">
            <input type="hidden" name="paymentMethod" value="<%= data.paymentMethod %>">
            <input type="hidden" name="paymentDate" value="<%= data.paymentDate %>">
            <input type="hidden" name="keteranganFrp" value="<%= data.keteranganFrp || '' %>">
            <!-- Serialize items -->
            <% data.items.forEach((item, idx) => { %>
                <input type="hidden" name="items[<%= idx %>][memo]" value="<%= item.memo %>">
                <input type="hidden" name="items[<%= idx %>][budgetId]" value="<%= item.budgetId %>">
                <input type="hidden" name="items[<%= idx %>][amount]" value="<%= item.amount %>">
            <% }); %>
            <% if(data.checkDocs) { data.checkDocs.forEach(d => { %>
                <input type="hidden" name="checkDocs[]" value="<%= d %>">
            <% }); } %>
            
            <button type="submit" formaction="/preview" class="btn btn-sm" style="background: white; color: var(--secondary); border: 1.5px solid var(--secondary);">
                <span class="material-icons-round">visibility</span> Preview
            </button>
            <button type="submit" formaction="/generate-pdf" class="btn btn-sm btn-generate">
                <span class="material-icons-round">download</span> Download
            </button>
        </form>

        <% if (['Manager', 'Direktur', 'Komisaris'].includes(user.jobLevel) || isIT) { %>
            <button type="button" class="btn btn-sm" style="background: #f59e0b; color: white;" onclick="doAction('reject')">
                <span class="material-icons-round">cancel</span> Reject
            </button>
        <% } %>
        <% if (isIT) { %>
            <button type="button" class="btn btn-sm" style="background: var(--dark); color: white;" onclick="doAction('revert')">
                <span class="material-icons-round">undo</span> Revert
            </button>
            <button type="button" class="btn btn-sm" style="background: var(--success); color: white;" onclick="saveEdits()">
                <span class="material-icons-round">save</span> Save
            </button>
        <% } %>
    <% } %>

    <% if(data.status === 'PENDING') { %>
        <% if (['Manager', 'Direktur', 'Komisaris'].includes(user.jobLevel) || isIT) { %>
            <button type="button" class="btn btn-sm" style="background: var(--danger); color: white;" onclick="doAction('delete')">
                <span class="material-icons-round">delete</span> Hapus
            </button>
            <button type="button" class="btn btn-sm" style="background: #f59e0b; color: white;" onclick="doAction('reject')">
                <span class="material-icons-round">cancel</span> Reject
            </button>
            <button type="button" class="btn btn-sm btn-generate" onclick="doAction('approve')">
                <span class="material-icons-round">check_circle</span> Approve
            </button>
            <% if (isIT) { %>
              <button type="button" class="btn btn-sm" style="background: var(--success); color: white;" onclick="saveEdits()">
                  <span class="material-icons-round">save</span> Save
              </button>
            <% } %>
        <% } else if (data.createdBy === user.fullName) { %>
            <button type="button" class="btn btn-sm" style="background: var(--danger); color: white;" onclick="doAction('delete')">
                <span class="material-icons-round">delete</span> Hapus
            </button>
        <% } %>
    <% } %>

    <% if(data.status === 'REJECTED') { %>
        <% if (['Manager', 'Direktur', 'Komisaris'].includes(user.jobLevel) || isIT || data.createdBy === user.fullName) { %>
            <button type="button" class="btn btn-sm" style="background: var(--danger); color: white;" onclick="doAction('delete')">
                <span class="material-icons-round">delete</span> Hapus
            </button>
        <% } %>
        <% if (isIT) { %>
            <button type="button" class="btn btn-sm" style="background: var(--primary); color: white;" onclick="doAction('revert')">
                <span class="material-icons-round">undo</span> Revert
            </button>
            <button type="button" class="btn btn-sm" style="background: var(--success); color: white;" onclick="saveEdits()">
                <span class="material-icons-round">save</span> Save
            </button>
        <% } %>
    <% } %>
  </div>

  <script>
    async function doAction(action) {
      if(!confirm(`Anda yakin ingin melakukan ${action}?`)) return;
      try {
        const res = await fetch(`/api/frp/<%= data.id %>/${action}`, { method: 'POST' });
        const result = await res.json();
        if(result.success) {
            window.parent.postMessage('refresh', '*');
        } else {
            alert('Gagal mengeksekusi aksi.');
        }
      } catch(e) {
        alert('Gagal mengeksekusi');
      }
    }

    async function saveEdits() {
      const form = document.getElementById('detailForm');
      const formData = new FormData(form);
      const dataObj = Object.fromEntries(formData.entries());
      
      // Parse items correctly
      dataObj.items = [];
      const rows = document.querySelectorAll('.line-item-row');
      rows.forEach((row, i) => {
        dataObj.items.push({
          memo: formData.get(`items[${i}][memo]`),
          budgetId: formData.get(`items[${i}][budgetId]`),
          amount: formData.get(`items[${i}][amount]`)
        });
      });
      dataObj.checkDocs = formData.getAll('checkDocs[]');

      try {
        const res = await fetch(`/api/frp/<%= data.id %>/update`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dataObj)
        });
        const result = await res.json();
        if(result.success) {
            alert('Perubahan berhasil disimpan!');
            window.parent.postMessage('refresh', '*');
        } else {
            alert('Gagal menyimpan perubahan.');
        }
      } catch(e) {
        alert('Gagal menyimpan.');
      }
    }
  </script>
</body>
</html>
