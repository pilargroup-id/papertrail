<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .status-badge {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      display: inline-block;
    }
    .status-PENDING { background: #fef08a; color: #854d0e; }
    .status-APPROVED { background: #bbf7d0; color: #166534; }
    .status-REJECTED { background: #fecaca; color: #991b1b; }
    .row-clickable { cursor: pointer; transition: all 0.2s; }
    .row-clickable:hover td { background: var(--primary-light) !important; }
    
    /* Filter Bar Styles */
    .filter-bar {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      padding: 20px;
      border-radius: 16px;
      margin-bottom: 25px;
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .filter-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1.5fr 1fr 1fr;
      gap: 15px;
      align-items: flex-end;
    }
    @media (max-width: 900px) {
      .filter-grid { grid-template-columns: 1fr 1fr; }
    }
    .filter-group label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--text-light);
      margin-bottom: 6px;
      letter-spacing: 0.5px;
    }
    .filter-group input, .filter-group select {
      width: 100%;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1.5px solid #e2e8f0;
      font-size: 13px;
      transition: all 0.2s;
      background: white;
    }
    .filter-group input:focus, .filter-group select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
      outline: none;
    }
  </style>
</head>
<body>
  <div class="bg-gradient"></div>
  <div class="bg-grid"></div>

  <nav class="navbar">
    <div class="nav-brand">
      <span class="material-icons-round brand-icon">payments</span>
      <div>
        <h1 class="nav-title">FRP System</h1>
        <p class="nav-subtitle">Halo, <%= user.fullName %> (<%= user.class %>)</p>
      </div>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link"><span class="material-icons-round">add_circle</span> New Request</a>
      <a href="/approval" class="nav-link <%= !isApprovedView ? 'active' : '' %>"><span class="material-icons-round">pending_actions</span> Approval</a>
      <a href="/approved" class="nav-link <%= isApprovedView ? 'active' : '' %>">
        <span class="material-icons-round">check_circle</span>
        <span>Approved</span>
      </a>
      <% if(locals.user && user.class === 'IT') { %>
        <a href="/admin/employees" class="nav-link" style="color: var(--primary-dark);">
          <span class="material-icons-round">admin_panel_settings</span>
          <span>Master Data</span>
        </a>
      <% } %>
      <a href="/logout" class="nav-link" style="color: var(--danger);">
        <span class="material-icons-round">logout</span>
        <span>Logout</span>
      </a>
    </div>
  </nav>

  <main class="main-content">
    <div class="form-container">
      <div class="header-card">
        <div class="header-icon-wrap" style="background: linear-gradient(135deg, <%= isApprovedView ? '#10b981, #059669' : '#f59e0b, #d97706' %>);">
          <span class="material-icons-round"><%= isApprovedView ? 'verified' : 'rule' %></span>
        </div>
        <div>
        </div>
      </div>
      
      <!-- Filter Bar -->
      <div class="filter-bar">
        <div class="filter-grid">
          <div class="filter-group">
            <label><span class="material-icons-round" style="font-size: 14px; vertical-align: middle;">search</span> Search</label>
            <input type="text" id="searchFilter" placeholder="Cari No FRP / Vendor..." oninput="filterTable()">
          </div>
          <div class="filter-group">
            <label><span class="material-icons-round" style="font-size: 14px; vertical-align: middle;">calendar_today</span> Tanggal</label>
            <input type="date" id="dateFilter" onchange="filterTable()">
          </div>
          <div class="filter-group">
            <label><span class="material-icons-round" style="font-size: 14px; vertical-align: middle;">person</span> Pemohon</label>
            <input type="text" id="requesterFilter" placeholder="Nama Pemohon..." oninput="filterTable()">
          </div>
          
          <% if (isApprovedView) { %>
          <div class="filter-group">
            <label><span class="material-icons-round" style="font-size: 14px; vertical-align: middle;">flag</span> Status</label>
            <select id="statusFilter" onchange="filterTable()">
              <option value="">Semua Status</option>
              <option value="APPROVED">APPROVED</option>
              <option value="REJECTED">REJECTED</option>
            </select>
          </div>
          <% } else { %>
            <div></div> <!-- Spacer -->
          <% } %>

          <% if (user.class === 'IT') { %>
          <div class="filter-group">
            <label><span class="material-icons-round" style="font-size: 14px; vertical-align: middle;">business</span> Divisi</label>
            <select id="divisionFilter" onchange="filterTable()">
              <option value="">Semua Divisi</option>
              <% 
                // Mendapatkan list divisi unik dari requests
                const divisions = [...new Set(requests.map(r => r.divisi))].sort();
                divisions.forEach(d => { 
              %>
                <option value="<%= d %>"><%= d %></option>
              <% }); %>
            </select>
          </div>
          <% } else { %>
            <div></div> <!-- Spacer -->
          <% } %>
        </div>
      </div>

      <div class="history-list">
        <% if (requests && requests.length > 0) { %>
          <table class="history-table">
            <thead>
              <tr>
                <th>No FRP</th>
                <th>Tanggal</th>
                <th>Pemohon</th>
                <th>Vendor</th>
                <th>Memo</th>
                <th>Keterangan</th>
                <th>Divisi</th>
                <th>Total Nominal</th>
                <% if (isApprovedView) { %><th>Approved By</th><% } %>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% requests.forEach(r => { 
                // Extract summary data
                const firstMemo = (r.items && r.items.length > 0) ? r.items[0].memo : '-';
                const keterangan = r.keteranganFrp || '-';

                // Kalkulasi total
                let total = 0;
                if(r.items) {
                    r.items.forEach(i => {
                        const raw = String(i.amount || '0').replace(/\./g, '').replace(/[^0-9]/g, '');
                        total += parseInt(raw, 10) || 0;
                    });
                }
              %>
                <tr class="row-clickable" onclick="openPopup('<%= r.id %>')">
                  <td><strong><%= r.frpNo %></strong></td>
                  <td><%= r.tanggalFrp %></td>
                  <td><%= r.dimintaOleh %></td>
                  <td><%= r.vendor %></td>
                  <td title="<%= firstMemo %>"><div style="max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= firstMemo %></div></td>
                  <td title="<%= keterangan %>"><div style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= keterangan %></div></td>
                  <td><%= r.divisi %></td>
                  <td style="font-family: monospace; font-weight: bold; text-align: right;">IDR <%= total.toLocaleString('id-ID') %></td>
                  <% if (isApprovedView) { %>
                    <td><%= r.approvedBy || r.approvedByActual || '-' %></td>
                  <% } %>
                  <td><span class="status-badge status-<%= r.status %>"><%= r.status %></span></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <span class="material-icons-round">task</span>
            <h3>Belum Ada Data</h3>
            <p>Tidak ada pengajuan di daftar ini.</p>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <!-- Modal Popup -->
  <div class="modal-overlay" id="detailModal">
    <div class="modal-content" style="max-width: 1000px; height: 95vh;">
      <div class="modal-header">
        <h3><span class="material-icons-round">description</span> Detail FRP</h3>
        <button class="modal-close" onclick="closePopup()"><span class="material-icons-round">close</span></button>
      </div>
      <div class="modal-body" style="padding: 0; background: #f8fafc; overflow: hidden;">
        <iframe id="detailIframe" style="width: 100%; height: 100%; border: none;"></iframe>
      </div>
    </div>
  </div>

  <div id="toast" class="toast"></div>

  <script>
    const modal = document.getElementById('detailModal');
    const iframe = document.getElementById('detailIframe');
    
    function openPopup(id) {
      iframe.src = '/frp/' + id;
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      modal.classList.remove('active');
      document.body.style.overflow = 'auto';
      iframe.src = '';
    }
    
    // Close on click outside
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closePopup();
    });

    // Listen to messages from iframe to close/refresh
    window.addEventListener('message', function(e) {
        if(e.data === 'refresh') {
            window.location.reload();
        }
    });

    // TABLE FILTERING LOGIC
    function filterTable() {
      const searchVal = document.getElementById('searchFilter').value.toLowerCase();
      const dateVal = document.getElementById('dateFilter').value; // yyyy-mm-dd
      const requesterVal = document.getElementById('requesterFilter').value.toLowerCase();
      const statusFilter = document.getElementById('statusFilter');
      const statusVal = statusFilter ? statusFilter.value : '';
      const divisionFilter = document.getElementById('divisionFilter');
      const divisionVal = divisionFilter ? divisionFilter.value : '';

      const rows = document.querySelectorAll('.history-table tbody tr');

      rows.forEach(row => {
        const cells = row.cells;
        const frpNo = cells[0].innerText.toLowerCase();
        const dateRaw = cells[1].innerText;
        const requester = cells[2].innerText.toLowerCase();
        const vendor = cells[3].innerText.toLowerCase();
        const division = cells[6].innerText;
        // Status is always the last cell (works with/without Approved By column)
        const status = cells[cells.length - 1].innerText.trim();

        const matchesSearch = frpNo.includes(searchVal) || vendor.includes(searchVal);
        const matchesDate = !dateVal || dateRaw === dateVal;
        const matchesRequester = requester.includes(requesterVal);
        const matchesStatus = !statusVal || status === statusVal;
        const matchesDivision = !divisionVal || division === divisionVal;

        row.style.display = (matchesSearch && matchesDate && matchesRequester && matchesStatus && matchesDivision) ? '' : 'none';
      });
    }
  </script>
</body>
</html>
