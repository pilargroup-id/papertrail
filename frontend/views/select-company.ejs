<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pilih Perusahaan - FRP System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <style>
        :root { --primary: #4f46e5; --secondary: #0ea5e9; --bg: #f8fafc; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: white; padding: 3rem; border-radius: 2rem; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1); width: 100%; max-width: 500px; text-align: center; border: 1px solid #e2e8f0; }
        .icon-box { width: 64px; height: 64px; background: var(--primary-light, #e0e7ff); border-radius: 1rem; display: flex; align-items: center; justify-content: center; color: var(--primary); margin: 0 auto 2rem; }
        h1 { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: 2rem; }
        .company-grid { display: flex; flex-direction: column; gap: 1rem; }
        .company-btn {
            display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; border: 1.5px solid #e2e8f0; border-radius: 1.25rem;
            background: white; cursor: pointer; transition: all 0.2s; text-align: left; width: 100%; font-size: 1rem; font-weight: 600; color: #334155;
        }
        .company-btn:hover { border-color: var(--primary); background: #f5f3ff; color: var(--primary); transform: translateX(5px); }
        .company-btn .material-icons-round { color: #cbd5e1; }
        .company-btn:hover .material-icons-round { color: var(--primary); }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-box"><span class="material-icons-round">business</span></div>
        <h1>Pilih Perusahaan</h1>
        <p style="color:#64748b; margin-bottom:1.5rem; font-size:0.875rem;">Pilih perusahaan tempat Anda bertugas</p>
        <form action="/select-company" method="POST" class="company-grid">
            <% companies.forEach(company => { %>
                <button type="submit" name="company" value="<%= company %>" class="company-btn">
                    <span><%= company %></span>
                    <span class="material-icons-round">chevron_right</span>
                </button>
            <% }); %>
        </form>
        <a href="/logout" style="display:inline-flex;align-items:center;gap:6px;margin-top:1.5rem;color:#94a3b8;font-size:0.875rem;text-decoration:none;font-weight:500;">
            <span class="material-icons-round" style="font-size:16px;">logout</span> Logout
        </a>
    </div>
</body>
</html>
