<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Animated Background -->
  <div class="bg-gradient"></div>
  <div class="bg-grid"></div>

  <!-- Navigation -->
  <nav class="navbar">
    <div class="nav-brand">
      <span class="material-icons-round brand-icon">payments</span>
      <div>
        <h1 class="nav-title">FRP System</h1>
        <p class="nav-subtitle">Form Request Payment</p>
      </div>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link">
        <span class="material-icons-round">add_circle</span>
        <span>New Request</span>
      </a>
      <a href="/history" class="nav-link active">
        <span class="material-icons-round">history</span>
        <span>History</span>
      </a>
    </div>
  </nav>

  <main class="main-content">
    <div class="form-container" style="max-width: 900px;">
      <div class="header-card">
        <div class="header-icon-wrap" style="background: linear-gradient(135deg, #10b981, #059669);">
          <span class="material-icons-round">folder_open</span>
        </div>
        <div>
          <h2>Document History</h2>
          <p>Daftar semua FRP PDF yang telah di-generate</p>
        </div>
      </div>

      <div class="history-list">
        <% if (files && files.length > 0) { %>
          <table class="history-table">
            <thead>
              <tr>
                <th>Nama File</th>
                <th>Tanggal Generate</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% files.forEach(file => { %>
                <tr>
                  <td>
                    <div style="display: flex; align-items: center; gap: 8px;">
                      <span class="material-icons-round" style="color: #ef4444;">picture_as_pdf</span>
                      <strong><%= file.name %></strong>
                    </div>
                  </td>
                  <td><%= file.date.toLocaleString('id-ID') %></td>
                  <td>
                    <a href="<%= file.path %>" class="btn btn-download" download>
                      <span class="material-icons-round">download</span> Download
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <span class="material-icons-round">hourglass_empty</span>
            <h3>Belum Ada Dokumen</h3>
            <p>Silakan buat Form Request Payment baru untuk melihat riwayat di sini.</p>
            <a href="/" class="btn btn-primary" style="margin-top: 15px; display: inline-flex; align-items: center; gap: 5px;">
              <span class="material-icons-round">add</span> Buat FRP
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
